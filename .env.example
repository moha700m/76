# Runtime mode: dry-run is the safe default. Change to live only after each platform is approved and tested.
SOCIAL_PUBLISH_MODE=dry-run
ADMIN_API_TOKEN=replace-with-32-plus-random-characters
CRON_SECRET=replace-with-32-plus-random-characters

# Existing low-cost OpenAI routing. Keep server-side only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# AppDeploy remains the heavy AI/auth/storage engine.
APPDEPLOY_STUDIO_URL=https://441a4987f6936b832e.v2.appdeploy.ai/

# YouTube OAuth 2.0 (scope: https://www.googleapis.com/auth/youtube.upload)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Login Kit + Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_POST_MODE=draft

# Instagram professional account publishing
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_GRAPH_API_VERSION=vXX.X

# Vercel Cron dispatches the GitHub social workflow
GITHUB_DISPATCH_TOKEN=
GITHUB_REPOSITORY=moha700m/REPOSITORY_NAME
GITHUB_WORKFLOW_FILE=social-publish.yml
GITHUB_DEFAULT_BRANCH=main

# GitHub Action -> Vercel secure publishing endpoint
SOCIAL_PUBLISH_ENDPOINT=https://YOUR-PROJECT.vercel.app/api/social/publish
SOCIAL_PUBLISH_ADMIN_TOKEN=

# Daily AppDeploy backup workflow
APPDEPLOY_BACKUP_ENDPOINT=https://441a4987f6936b832e.v2.appdeploy.ai/api/admin/backup
APPDEPLOY_BACKUP_TOKEN=

# Reports and audits
PRODUCTION_URL=https://YOUR-PROJECT.vercel.app
CONTENT_QUEUE_DIR=content/pending-uploads
